{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug webserv",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/webserv",
            "args": ["config.conf"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build webserv"
        },
        {
            "name": "Attach to webserv",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/webserv",
            "pid": "${command:pickProcess}"
        }
    ]
}